{
  "manifest_version": 3,

  "name": "Social Media AI Detector",

  "version": "1.0",

  "host_permissions": [
    "https://www.instagram.com/*",
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}